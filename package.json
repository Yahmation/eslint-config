{
  "name": "@yahmation/eslint-config",
  "version": "1.2.1",
  "description": "Shared ESLint flat config + cross-reference verifier for all Yahmation projects (web + mobile + API). Catches the class of bugs where code references functions/variables that don't exist at write time.",
  "type": "module",
  "main": "base.config.mjs",
  "exports": {
    ".": "./base.config.mjs"
  },
  "bin": {
    "verify-symbols": "./verify-symbols.js"
  },
  "files": [
    "base.config.mjs",
    "verify-symbols.js",
    "README.md"
  ],
  "keywords": [
    "eslint",
    "eslintconfig",
    "yahmation"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yahmation/eslint-config.git"
  },
  "dependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.13.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": false
    }
  }
}
